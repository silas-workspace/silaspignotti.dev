---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHead from '@/components/PageHead.astro'
import ProjectCard from '@/components/ProjectCard.astro'
import CategoryFilter from '@/components/react/category-filter'
import Layout from '@/layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { getAllProjects } from '@/lib/data-utils'

const page = (await getCollection('pages')).find((entry) => entry.data.slug === '/projects')

if (!page) {
  throw new Error('Missing pages/projects.md content entry')
}

const projects = await getAllProjects()

const currentUrl = Astro.url

const categories = ['All', 'Geospatial', 'AI/Automation'] as const
---

<Layout canonicalUrl={currentUrl}>
  <PageHead
    slot="head"
    title={page.data.title}
    description={page.data.description}
    imagePath={page.data.ogImage}
  />

  <section class="mx-auto mt-10 w-full max-w-7xl px-4 sm:px-8 md:mt-12 lg:px-12">
    <Breadcrumbs
      items={[
        { label: 'Projects', href: '/projects', icon: 'lucide:folder' },
      ]}
    />

    <header class="mb-10 mt-6">
      <h1 class="font-custom text-foreground text-4xl font-bold">{page.data.title}</h1>
      <p class="text-muted-foreground text-md mt-3">{page.data.description}</p>
    </header>

    <!-- Category Filter -->
    <CategoryFilter client:load categories={categories} />

    <!-- Projects Grid -->
    <ul 
      id="projects-grid"
      class="grid grid-cols-1 md:grid-cols-2 gap-6"
      role="list"
    >
      {
        projects.map((project) => (
          <li 
            class="project-item"
            data-category={project.data.category}
          >
            <ProjectCard project={project} tagLimit={3} />
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
