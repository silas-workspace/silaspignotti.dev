---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import Layout from '@/layouts/Layout.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { badgeVariants } from '@/components/ui/badge'
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import { Calendar, Layers, Terminal, Satellite, MapPin, FileSearch, LayoutDashboard, Wand2, Trees, Building2 } from 'lucide-react'

export async function getStaticPaths() {
  const projects = await getCollection('projects')
  return projects.map((project) => ({
    params: { id: project.data.slug },
    props: { project },
  }))
}

const { project } = Astro.props as { project: CollectionEntry<'projects'> }
const currentUrl = Astro.url
const { Content } = await render(project)
const displayYear = project.data.completed ? project.data.year : 'Ongoing'

// Icon mapping for coverIcon
const iconMap: Record<string, typeof Building2> = {
  'layers': Layers,
  'terminal': Terminal,
  'satellite': Satellite,
  'map-pin': MapPin,
  'file-search': FileSearch,
  'layout-dashboard': LayoutDashboard,
  'wand-2': Wand2,
  'trees': Trees,
  'building-2': Building2,
}

const IconComponent = iconMap[project.data.coverIcon] || Layers

const projectSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: project.data.title,
  description: project.data.description,
  codeRepository: project.data.github,
  keywords: project.data.tags,
  url: new URL(`/projects/${project.data.slug}`, Astro.site).toString(),
}
---

<Layout canonicalUrl={currentUrl}>
  <PageHead
    slot="head"
    title={`${project.data.title} | Project`}
    description={project.data.description}
  />

  <script type="application/ld+json" is:inline set:html={JSON.stringify(projectSchema)} />

  <section class="grid grid-cols-[minmax(0px,1fr)_min(calc(var(--breakpoint-lg)-2rem),100%)_minmax(0px,1fr)] gap-y-6 max-w-[calc(100vw-2rem)]">
    <div class="col-start-2">
      <Breadcrumbs
        items={[
          { href: '/projects', label: 'Projects', icon: 'lucide:folder' },
          { label: project.data.title, icon: 'lucide:folder-open' },
        ]}
      />
    </div>

    <section class="col-start-2 flex flex-col gap-y-6 text-start">
      <header>
        <!-- Icon + Title + Tagline Header (instead of cover image) -->
        <div class="flex items-center gap-4 mb-2">
          <!-- Icon Circle -->
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full border border-primary/50">
            <IconComponent className="h-7 w-7 text-primary" />
          </div>
          
          <div>
            <h1 class="text-3xl leading-tight font-medium text-pretty sm:text-5xl">
              {project.data.title}
            </h1>
            {project.data.tagline && <p class="text-foreground/90 text-base sm:text-lg mt-1">{project.data.tagline}</p>}
          </div>
        </div>

        <div class="mt-4 flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center gap-1 rounded-full bg-muted/50 px-3 py-1 text-xs font-medium text-muted-foreground">
            <Calendar className="h-3 w-3" />
            {displayYear}
          </span>
          <span class="inline-flex items-center gap-1 rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
            {project.data.category}
          </span>
        </div>

        <ul class="mt-4 flex flex-wrap gap-2" role="list" aria-label={`${project.data.title} tags`}>
          {
            project.data.tags.map((tag) => (
              <li class={badgeVariants({ variant: 'secondary' })}>{tag}</li>
            ))
          }
        </ul>
      </header>

      <article class="prose max-w-none" aria-label="Project details">
        <Content />

        {
          project.data.downloads && project.data.downloads.length > 0 && (
            <section aria-labelledby="downloads-title" class="not-prose mt-4 rounded-xl border border-border bg-card p-5">
              <h2 id="downloads-title" class="font-custom text-foreground text-2xl font-bold">Downloads</h2>
              <ul class="mt-3 list-disc space-y-2 pl-5">
                {project.data.downloads.map((item) => (
                  <li class="text-muted-foreground text-sm">
                    {item.href ? (
                      <Link
                        href={item.href}
                        external={item.href.startsWith('http://') || item.href.startsWith('https://')}
                        underline
                        class="text-primary"
                      >
                        {item.label}
                      </Link>
                    ) : (
                      <span class="text-foreground">{item.label}</span>
                    )}
                    {item.note ? <span class="text-muted-foreground"> — {item.note}</span> : null}
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        {
          project.data.screenshots && project.data.screenshots.length > 0 && (
            <section aria-labelledby="screenshots-title" class="not-prose mt-4 rounded-xl border border-border bg-card p-5">
              <h2 id="screenshots-title" class="font-custom text-foreground text-2xl font-bold">Screenshots</h2>
              <ul class="mt-4 grid gap-4 sm:grid-cols-2" role="list">
                {project.data.screenshots.map((screenshot) => (
                  <li class="overflow-hidden rounded-xl border border-border/60 bg-muted/30">
                    <img
                      src={screenshot.src}
                      alt={screenshot.alt}
                      class="h-full w-full object-cover"
                      loading="lazy"
                    />
                  </li>
                ))}
              </ul>
            </section>
          )
        }
      </article>
    </section>

    <aside class="group col-start-2 rounded-xl border p-4 xl:sticky xl:top-26 xl:col-start-3 xl:mr-auto xl:ml-8 xl:h-fit xl:max-w-fit xl:rounded-none xl:border-none xl:p-0">
      <div class="flex flex-col gap-4 rounded-xl border bg-card p-4 shadow-md transition-all duration-300 group-hover:shadow-lg xl:group-hover:shadow-none">
        <ul class="flex flex-col gap-3 text-sm text-muted-foreground">
          {project.data.github && (
            <>
              <li>
                <Link href={project.data.github} external underline class="text-primary">GitHub Repository</Link>
              </li>
              <li class="border-t border-border/40"></li>
            </>
          )}
          {project.data.demo && (
            <>
              <li>
                <Link href={project.data.demo} external underline class="text-primary">Live Demo</Link>
              </li>
              <li class="border-t border-border/40"></li>
            </>
          )}
          {project.data.pypi && (
            <>
              <li>
                <Link href={project.data.pypi} external underline class="text-primary">PyPI</Link>
              </li>
              <li class="border-t border-border/40"></li>
            </>
          )}
          {project.data.paper && (
            <>
              <li>
                <Link href={project.data.paper} external underline class="text-primary">Paper</Link>
              </li>
              <li class="border-t border-border/40"></li>
            </>
          )}
        </ul>

        <li class="border-t border-border/40 list-none"></li>

        <Link href="/projects" underline class="text-sm font-medium text-primary">
          Back to all projects
        </Link>
      </div>
    </aside>
  </section>
</Layout>
