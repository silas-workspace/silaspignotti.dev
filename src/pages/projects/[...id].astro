---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import Layout from '@/layouts/Layout.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { PROJECT_CASES } from '@/lib/project-cases'

export async function getStaticPaths() {
  return PROJECT_CASES.map((project) => ({
    params: { id: project.slug },
    props: project,
  }))
}

const project = Astro.props
const currentUrl = Astro.url
---

<Layout canonicalUrl={currentUrl}>
  <PageHead
    slot="head"
    title={`${project.name} | Project`}
    description="Project detail page coming soon."
  />
  <section class="flex flex-col gap-y-8 px-4 md:px-6">
    <Breadcrumbs
      items={[
        { href: '/projects', label: 'Projects', icon: 'lucide:folder' },
        { label: project.name, icon: 'lucide:folder-open' },
      ]}
    />

    <article class="bg-card border-border max-w-3xl rounded-xl border p-6">
      <h1 class="font-custom text-foreground text-3xl font-bold sm:text-4xl">{project.name}</h1>
      <p class="text-muted-foreground mt-3 text-sm leading-relaxed">
        Detailed project case is in progress.
      </p>
      <!-- TODO: Add full project case details (challenge, approach, architecture, outcomes). -->

      <div class="mt-6 flex flex-wrap items-center gap-3">
        <Link href="/projects" underline class="text-sm font-medium text-primary">
          Back to all projects
        </Link>
        <Link href={project.githubUrl} external underline class="text-sm font-medium text-muted-foreground">
          View on GitHub
        </Link>
      </div>
    </article>
  </section>
</Layout>
