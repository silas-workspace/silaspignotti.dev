---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import Layout from '@/layouts/Layout.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { badgeVariants } from '@/components/ui/badge'
import { withBasePath } from '@/lib/paths'
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

export async function getStaticPaths() {
  const projects = await getCollection('projects')
  return projects.map((project) => ({
    params: { id: project.data.slug },
    props: { project },
  }))
}

const { project } = Astro.props as { project: CollectionEntry<'projects'> }
const currentUrl = Astro.url
const { Content } = await render(project)
const coverPath = withBasePath(project.data.cover) ?? '/ogImage.png'

const projectSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: project.data.title,
  description: project.data.description,
  codeRepository: project.data.github,
  keywords: project.data.tags,
  url: new URL(`/projects/${project.data.slug}`, Astro.site).toString(),
  image: new URL(coverPath, Astro.site).toString(),
}
---

<Layout canonicalUrl={currentUrl} isWide>
  <PageHead
    slot="head"
    title={`${project.data.title} | Project`}
    description={project.data.description}
    imagePath={coverPath}
  />

  <script type="application/ld+json" is:inline set:html={JSON.stringify(projectSchema)} />

  <section class="mx-auto grid w-full max-w-7xl gap-y-6 px-4 sm:px-8 lg:px-12 xl:grid-cols-[minmax(0px,1fr)_18rem] xl:items-start xl:gap-x-8">
    <div class="xl:col-span-2">
      <Breadcrumbs
        items={[
          { href: '/projects', label: 'Projects', icon: 'lucide:folder' },
          { label: project.data.title, icon: 'lucide:folder-open' },
        ]}
      />
    </div>

    <section class="flex flex-col gap-y-6 text-start xl:col-start-1">
      <header>
        <div class="aspect-[16/8] w-full overflow-hidden rounded-2xl border border-border/60 bg-muted/40">
          <img
            src={coverPath}
            alt={`${project.data.title} cover image`}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>

        <h1 class="mt-6 mb-2 text-3xl leading-tight font-medium text-pretty sm:text-5xl">
          {project.data.title}
        </h1>
        {project.data.tagline && <p class="text-foreground/90 text-base sm:text-lg">{project.data.tagline}</p>}

        <div class="mt-4 flex flex-wrap items-center gap-2">
          <span class="text-muted-foreground text-sm">Category:</span>
          <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
            {project.data.category}
          </span>
        </div>

        <ul class="mt-4 flex flex-wrap gap-2" role="list" aria-label={`${project.data.title} tags`}>
          {
            project.data.tags.map((tag) => (
              <li class={badgeVariants({ variant: 'secondary' })}>{tag}</li>
            ))
          }
        </ul>
      </header>

      <article class="prose max-w-none" aria-label="Project details">
        <Content />

        {
          project.data.downloads && project.data.downloads.length > 0 && (
            <section aria-labelledby="downloads-title" class="not-prose mt-4 rounded-xl border border-border bg-card p-5">
              <h2 id="downloads-title" class="font-custom text-foreground text-2xl font-bold">Downloads</h2>
              <ul class="mt-3 list-disc space-y-2 pl-5">
                {project.data.downloads.map((item) => (
                  <li class="text-muted-foreground text-sm">
                    {item.href ? (
                      <Link
                        href={item.href}
                        external={item.href.startsWith('http://') || item.href.startsWith('https://')}
                        underline
                        class="text-primary"
                      >
                        {item.label}
                      </Link>
                    ) : (
                      <span class="text-foreground">{item.label}</span>
                    )}
                    {item.note ? <span class="text-muted-foreground"> — {item.note}</span> : null}
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        {
          project.data.screenshots && project.data.screenshots.length > 0 && (
            <section aria-labelledby="screenshots-title" class="not-prose mt-4 rounded-xl border border-border bg-card p-5">
              <h2 id="screenshots-title" class="font-custom text-foreground text-2xl font-bold">Screenshots</h2>
              <ul class="mt-4 grid gap-4 sm:grid-cols-2" role="list">
                {project.data.screenshots.map((screenshot) => (
                  <li class="overflow-hidden rounded-xl border border-border/60 bg-muted/30">
                    <img
                      src={withBasePath(screenshot.src)}
                      alt={screenshot.alt}
                      class="h-full w-full object-cover"
                      loading="lazy"
                    />
                  </li>
                ))}
              </ul>
            </section>
          )
        }
      </article>
    </section>

    <aside class="group rounded-xl border p-4 xl:sticky xl:top-26 xl:col-start-2 xl:h-fit xl:rounded-none xl:border-none xl:p-0">
      <div class="flex flex-col gap-4 rounded-xl border bg-card p-4 shadow-md transition-all duration-300 group-hover:shadow-lg xl:group-hover:shadow-none">
        <h2 class="text-lg font-semibold">Project Links</h2>
        <ul class="flex flex-col gap-2 text-sm text-muted-foreground">
          <li>
            <Link href={project.data.github} external underline class="text-primary">GitHub Repository</Link>
          </li>
          {project.data.demo && (
            <li>
              <Link href={project.data.demo} external underline class="text-primary">Live Demo</Link>
            </li>
          )}
          {project.data.paper && (
            <li>
              <Link href={project.data.paper} external underline class="text-primary">Paper</Link>
            </li>
          )}
        </ul>

        <hr class="my-2 border-t" />

        <Link href="/projects" underline class="text-sm font-medium text-primary">
          Back to all projects
        </Link>
      </div>
    </aside>
  </section>
</Layout>
