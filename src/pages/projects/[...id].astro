---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import Layout from '@/layouts/Layout.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { badgeVariants } from '@/components/ui/badge'
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import { Calendar, Layers, Terminal, Satellite, MapPin, FileSearch, LayoutDashboard, Wand2, Trees, Building2 } from 'lucide-react'

export async function getStaticPaths() {
  const projects = await getCollection('projects')
  return projects.map((project) => ({
    params: { id: project.data.slug },
    props: { project },
  }))
}

const { project } = Astro.props as { project: CollectionEntry<'projects'> }
const currentUrl = Astro.url
const { Content } = await render(project)
const displayYear = project.data.completed ? project.data.year : 'Ongoing'

// Icon mapping for coverIcon
const iconMap: Record<string, typeof Building2> = {
  'layers': Layers,
  'terminal': Terminal,
  'satellite': Satellite,
  'map-pin': MapPin,
  'file-search': FileSearch,
  'layout-dashboard': LayoutDashboard,
  'wand-2': Wand2,
  'trees': Trees,
  'building-2': Building2,
}

const IconComponent = iconMap[project.data.coverIcon] || Layers

const projectSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: project.data.title,
  description: project.data.description,
  codeRepository: project.data.github,
  keywords: project.data.tags,
  url: new URL(`/projects/${project.data.slug}`, Astro.site).toString(),
}

// Build list of all links with separators
const links: { label: string; href: string; external: boolean }[] = []
if (project.data.github) links.push({ label: 'GitHub Repository', href: project.data.github, external: true })
if (project.data.demo) links.push({ label: 'Live Demo', href: project.data.demo, external: true })
if (project.data.pypi) links.push({ label: 'PyPI Package', href: project.data.pypi, external: true })
if (project.data.paper) links.push({ label: 'Paper (PDF)', href: project.data.paper, external: true })
if (project.data.downloads) {
  project.data.downloads.forEach((item) => {
    if (item.href) {
      links.push({ label: item.label, href: item.href, external: item.href.startsWith('http') })
    }
  })
}
---

<Layout canonicalUrl={currentUrl}>
  <PageHead
    slot="head"
    title={`${project.data.title} | Project`}
    description={project.data.description}
  />

  <script type="application/ld+json" is:inline set:html={JSON.stringify(projectSchema)} />

  <section class="grid grid-cols-[minmax(0px,1fr)_min(calc(var(--breakpoint-lg)-2rem),100%)_minmax(0px,1fr)] gap-y-6 max-w-[calc(100vw-2rem)]">
    <div class="col-start-2">
      <Breadcrumbs
        items={[
          { href: '/projects', label: 'Projects', icon: 'lucide:folder' },
          { label: project.data.title, icon: 'lucide:folder-open' },
        ]}
      />
    </div>

    <section class="col-start-2 flex flex-col gap-y-6 text-start">
      <header>
        <!-- Icon + Title + Tagline Header (instead of cover image) -->
        <div class="flex items-center gap-4 mb-2">
          <!-- Icon Circle - larger -->
          <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full border border-primary/50">
            <IconComponent className="h-8 w-8 text-primary" />
          </div>
          
          <div>
            <h1 class="text-3xl leading-tight font-medium text-pretty sm:text-5xl">
              {project.data.title}
            </h1>
            {project.data.tagline && <p class="text-foreground/90 text-base sm:text-lg mt-1">{project.data.tagline}</p>}
          </div>
        </div>

        <div class="mt-4 flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center gap-1 rounded-full bg-muted/50 px-3 py-1 text-xs font-medium text-muted-foreground">
            <Calendar className="h-3 w-3" />
            {displayYear}
          </span>
          <span class="inline-flex items-center gap-1 rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
            {project.data.category}
          </span>
        </div>

        <ul class="mt-4 flex flex-wrap gap-2" role="list" aria-label={`${project.data.title} tags`}>
          {
            project.data.tags.map((tag) => (
              <li class={badgeVariants({ variant: 'secondary' })}>{tag}</li>
            ))
          }
        </ul>
      </header>

      <article class="prose max-w-none" aria-label="Project details">
        <Content />
      </article>

      {
        project.data.screenshots && project.data.screenshots.length > 0 && (
          <section class="mt-8">
            <h2 class="font-custom text-2xl font-bold text-foreground">Visuals</h2>
            <div class="mt-4 flex flex-col gap-4">
              {project.data.screenshots.map((screenshot) => (
                <img
                  src={screenshot.src}
                  alt={screenshot.alt}
                  class="w-full rounded-lg"
                  loading="lazy"
                />
              ))}
            </div>
          </section>
        )
      }
    </section>

    <aside class="group col-start-2 rounded-xl border p-4 xl:sticky xl:top-26 xl:col-start-3 xl:mr-auto xl:ml-8 xl:h-fit xl:max-w-fit xl:rounded-none xl:border-none xl:p-0">
      <div class="flex flex-col gap-3 rounded-xl border bg-card p-4 shadow-md transition-all duration-300 group-hover:shadow-lg xl:group-hover:shadow-none">
        <ul class="flex flex-col gap-3 text-sm text-muted-foreground">
          {links.map((link, index) => (
            <>
              <li>
                <Link href={link.href} external={link.external} underline class="text-primary">
                  {link.label}
                </Link>
              </li>
              {index < links.length - 1 && (
                <li class="border-t border-border/40"></li>
              )}
            </>
          ))}
        </ul>

        {links.length > 0 && <li class="border-t border-border/40 list-none"></li>}

        <Link href="/projects" underline class="text-sm font-medium text-primary">
          Back to all projects
        </Link>
      </div>
    </aside>
  </section>
</Layout>
