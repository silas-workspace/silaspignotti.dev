---
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
import Link from '@/components/Link.astro'
import Skills from '@/components/react/skills'
import ProjectCard from '@/components/ProjectCard.astro'
import { getCollection } from 'astro:content'
import { SITE } from '@/consts'

const currentUrl = Astro.url
const page = (await getCollection('pages')).find((entry) => entry.data.slug === '/')
const featuredProjects = (await getCollection('projects'))
  .filter((project) => project.data.featured)
  .sort((a, b) => {
    const aYear = a.data.year ?? 0
    const bYear = b.data.year ?? 0
    if (bYear !== aYear) return bYear - aYear
    const aOngoing = a.data.completed ? 1 : 0
    const bOngoing = b.data.completed ? 1 : 0
    return aOngoing - bOngoing
  })
  .slice(0, 3)

if (!page) {
  throw new Error('Missing pages/landing.md content entry')
}

const normalizedBody = (page.body ?? '').replace(/\r\n/g, '\n')

const extractSection = (title: string) => {
  const escaped = title.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
  const regex = new RegExp(`##\\s+${escaped}\\s*([\\s\\S]*?)(?=\\n##\\s+|$)`)
  return normalizedBody.match(regex)?.[1]?.trim() ?? ''
}

const whatIDoSection = extractSection('What I Do')
const whatIDoItems = whatIDoSection
  .split(/\n###\s+/)
  .map((part, index) => {
    const normalizedPart = (index === 0 ? part.replace(/^###\s+/, '') : part).trim()
    if (!normalizedPart) return null
    const [title, ...rest] = normalizedPart.split('\n')
    return {
      title: title?.trim() ?? '',
      description: rest.join('\n').trim().replace(/\n+/g, ' '),
    }
  })
  .filter((item): item is { title: string; description: string } => Boolean(item?.title && item?.description))

const ctaSection = extractSection('Get in Touch')
const ctaText = ctaSection.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '').trim().replace(/\n+/g, ' ')
---

<Layout canonicalUrl={currentUrl}>
  <PageHead
    slot="head"
    title={page.data.title}
    description={page.data.description}
    imagePath={page.data.ogImage}
  />

  <section class="mx-auto w-full max-w-7xl px-4 pb-8 sm:px-8 sm:pb-10 lg:px-12">
    <h1 class="font-custom max-w-4xl text-4xl leading-tight font-bold text-foreground sm:text-5xl lg:text-6xl">
      Portfolio | Silas Pignotti
    </h1>
    <p class="mt-3 text-lg sm:text-xl text-muted-foreground">
      Geo Data Scientist · AI Engineer
    </p>
    <p class="mt-4 max-w-3xl text-base leading-relaxed text-muted-foreground sm:mt-5">
      M.Sc. Geoinformation student at BHT Berlin. Building geospatial ML systems and AI tooling.
    </p>
    <div class="mt-6 flex flex-wrap gap-2.5 sm:mt-7 sm:gap-3">
      <Link href={`mailto:${SITE.email}`} class="rounded-full border border-primary bg-transparent px-5 py-2.5 text-sm font-semibold text-primary transition-colors hover:bg-primary/10">
        Get in Touch
      </Link>
    </div>
  </section>

  {whatIDoItems.length > 0 && (
    <section aria-labelledby="what-i-do-heading" class="mx-auto w-full max-w-7xl px-4 pb-8 sm:px-8 lg:px-12">
      <div class="mb-6">
        <h2 id="what-i-do-heading" class="font-custom text-2xl font-bold text-foreground sm:text-3xl">What I Do</h2>
      </div>
      <ul class="grid grid-cols-1 gap-3.5 md:grid-cols-3 md:gap-4" role="list">
        {whatIDoItems.map((item) => (
          <li class="rounded-2xl border border-border/60 bg-card p-5 shadow-sm">
            <h3 class="text-lg font-semibold text-foreground">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{item.description}</p>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section aria-labelledby="skills-heading" class="mx-auto w-full max-w-7xl px-4 pb-9 sm:px-8 sm:pb-10 lg:px-12">
    <div class="mb-4 flex items-end justify-between gap-4">
      <div>
        <h2 id="skills-heading" class="font-custom text-2xl font-bold text-foreground sm:text-3xl">
          Skills & Technologies
        </h2>
        <p class="mt-2 text-sm text-muted-foreground sm:text-base">
          Core tools and platforms used across geospatial analysis, machine learning, and production workflows.
        </p>
      </div>
    </div>
    <Skills client:load />
  </section>

  {featuredProjects.length > 0 && (
    <section aria-labelledby="featured-projects-heading" class="mx-auto w-full max-w-7xl px-4 pb-9 sm:px-8 sm:pb-10 lg:px-12">
      <div class="mb-6 flex items-end justify-between gap-4">
        <div>
          <h2 id="featured-projects-heading" class="font-custom text-2xl font-bold text-foreground sm:text-3xl">
            Featured Projects
          </h2>
          <p class="mt-2 text-sm text-muted-foreground sm:text-base">
            Selected projects that represent core strengths across geospatial ML and AI tooling.
          </p>
        </div>
        <Link href="/projects" class="text-sm font-medium text-primary" underline>
          View all
        </Link>
      </div>

      <ul class="grid grid-cols-1 gap-5 md:grid-cols-2 md:gap-6 xl:grid-cols-3" role="list">
        {featuredProjects.map((project) => (
          <li>
            <ProjectCard project={project} variant="featured" headingLevel="h3" tagLimit={4} />
          </li>
        ))}
      </ul>
    </section>
  )}

  <section aria-labelledby="landing-cta-heading" class="mx-auto w-full max-w-7xl px-4 pb-2 sm:px-8 lg:px-12">
    <h2 id="landing-cta-heading" class="font-custom text-2xl font-bold text-foreground sm:text-3xl">Get in Touch</h2>
    {ctaText && <p class="mt-3 text-sm leading-relaxed text-muted-foreground sm:text-base">{ctaText.replace(/\s*Based in Berlin\.\s*$/, '').trim()}</p>}
    <p class="mt-4 text-base text-muted-foreground">Based in Berlin.</p>
    <div class="mt-5 flex flex-wrap gap-3">
      <a href="mailto:pignottisilas@gmail.com" class="inline-flex items-center gap-2 rounded-full border border-primary bg-transparent px-6 py-3 text-base font-semibold text-primary transition-colors hover:bg-primary/10">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Email
      </a>
      <a href="https://www.linkedin.com/in/silas-pignotti/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full border border-primary bg-transparent px-6 py-3 text-base font-semibold text-primary transition-colors hover:bg-primary/10">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        LinkedIn
      </a>
    </div>
  </section>
</Layout>
