---
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'

const currentUrl = Astro.url

const experience = [
  {
    role: 'Data Analytics',
    company: 'Interzero Plastics Sorting GmbH',
    dateRange: '2025–present',
    description:
      'KPI automation on industrial plant data (Python, SQL). Migrated manual Excel workflows to reproducible, SQL-based analysis pipelines.',
  },
  {
    role: 'Construction Management',
    company: 'Büro Tacke e.K.',
    dateRange: '2023–2025',
    description:
      'AI-powered database maintenance, GIS-based analyses for funding applications, project oversight for a sustainable housing development (51 units, €11.5M).',
  },
  {
    role: 'Location Development',
    company: 'LOKATION:S',
    dateRange: '2022–2023',
    description:
      'GIS-based site and market analysis for municipal and private stakeholders. Analytical reports, maps, and visualizations for strategic decisions.',
  },
  {
    role: 'Project Development',
    company: 'KlimaGut AG',
    dateRange: '2021–2022',
    description:
      'Real estate database management, GIS-based site analysis with direct impact on investment decisions.',
  },
]

const education = [
  {
    degree: 'M.Sc. Geoinformation',
    institution: 'BHT Berlin',
    dateRange: '2024–2026 (expected)',
    gpa: '1.15',
    details: [
      'Focus: Geoinformatics, Remote Sensing, Spatial Data Science',
      'Thesis (planned): Urban Heat Islands. Remote Sensing, ML, Cloud Infrastructure',
    ],
  },
  {
    degree: 'B.Sc. Urban & Regional Planning',
    institution: 'TU Berlin',
    dateRange: '2020–2024',
    gpa: '1.6',
    details: [
      'Thesis: "Hidden Champions in Large Cities: A Web-Data-Based Investigation Using Berlin as a Case Study" (Grade: 1.2)',
    ],
  },
]

const skillClusters = [
  {
    title: 'Geospatial Data Science',
    description:
      'Spatial data analysis and processing (vector, raster, satellite data). Machine learning on geodata: feature engineering, training, evaluation. Earth observation and remote sensing. Data visualization and reporting.',
    tags: [
      'PostGIS',
      'GeoPandas',
      'rasterio',
      'xarray',
      'Google Earth Engine',
      'Sentinel Hub',
      'QGIS',
      'scikit-learn',
      'XGBoost',
      'PyTorch',
      'Matplotlib',
      'Plotly',
    ],
  },
  {
    title: 'AI & Automation',
    description:
      'Prompt and Context Engineering. Agentic systems and workflow automation. RAG systems with domain-specific knowledge bases.',
    tags: ['LangChain', 'LangGraph', 'LiteLLM', 'Vector Databases'],
  },
  {
    title: 'Cross-Cutting',
    description:
      'Data engineering: ETL/ELT pipelines, SQL-based analysis, cloud infrastructure. Backend and tooling: API development, containerization, version control.',
    tags: [
      'Python',
      'SQL',
      'R',
      'FastAPI',
      'Docker',
      'Git/GitHub',
      'Linux',
      'PostgreSQL',
    ],
  },
  {
    title: 'Languages',
    description: 'German (native), English (fluent)',
    tags: ['German (native)', 'English (fluent)'],
  },
]
---

<Layout canonicalUrl={currentUrl}>
  <PageHead
    slot="head"
    title="About"
    description="Geo Data Scientist based in Berlin, currently finishing an M.Sc. in Geoinformation at BHT Berlin. Background in Urban Planning with experience in geospatial analysis, automation, and AI workflows."
  />

  <section class="flex flex-col gap-y-12 px-4 py-8 sm:px-8 lg:px-16">
    <section aria-labelledby="about-title" class="flex flex-col gap-y-4">
      <h1 id="about-title" class="font-custom text-foreground text-4xl font-extrabold sm:text-5xl">
        About
      </h1>
      <p class="text-foreground max-w-4xl text-base leading-relaxed sm:text-lg">
        I'm a Geo Data Scientist based in Berlin, currently finishing my M.Sc. in Geoinformation at BHT Berlin (GPA 1.15). I studied Urban Planning at TU Berlin before that. Working with cities and infrastructure is what drew me to geospatial data in the first place.
      </p>
      <p class="text-foreground max-w-4xl text-base leading-relaxed sm:text-lg">
        Day to day, that means building ML pipelines on satellite imagery, automating analytical workflows with Python and SQL, and developing open-source tools. I also build AI-powered automation into my own work: structured prompts, agentic systems, reproducible documentation. Not as a separate discipline, but as a natural part of how I approach problems.
      </p>
    </section>

    <section aria-labelledby="experience-title" class="flex flex-col gap-y-5">
      <h2 id="experience-title" class="font-custom text-foreground text-2xl font-bold">Experience</h2>
      <ul class="flex flex-col gap-4" role="list">
        {
          experience.map((item) => (
            <li>
              <article class="bg-card border-border rounded-xl border p-5 shadow-sm">
                <header class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                  <h3 class="text-foreground text-lg font-semibold">
                    {item.role} <span class="text-muted-foreground">· {item.company}</span>
                  </h3>
                  <p class="text-muted-foreground text-sm font-medium">{item.dateRange}</p>
                </header>
                <p class="text-muted-foreground mt-3 text-sm leading-relaxed">{item.description}</p>
              </article>
            </li>
          ))
        }
      </ul>
    </section>

    <section aria-labelledby="education-title" class="flex flex-col gap-y-5">
      <h2 id="education-title" class="font-custom text-foreground text-2xl font-bold">Education</h2>
      <ul class="flex flex-col gap-4" role="list">
        {
          education.map((item) => (
            <li>
              <article class="bg-card border-border rounded-xl border p-5 shadow-sm">
                <header class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                  <h3 class="text-foreground text-lg font-semibold">
                    {item.degree} <span class="text-muted-foreground">· {item.institution}</span>
                  </h3>
                  <p class="text-muted-foreground text-sm font-medium">{item.dateRange}</p>
                </header>
                <p class="text-foreground mt-2 text-sm font-medium">GPA {item.gpa}</p>
                <ul class="mt-3 list-disc space-y-1 pl-5">
                  {item.details.map((detail) => <li class="text-muted-foreground text-sm leading-relaxed">{detail}</li>)}
                </ul>
              </article>
            </li>
          ))
        }
      </ul>
    </section>

    <section aria-labelledby="skills-title" class="flex flex-col gap-y-5">
      <h2 id="skills-title" class="font-custom text-foreground text-2xl font-bold">Skills</h2>
      <ul class="grid gap-4 md:grid-cols-2" role="list">
        {
          skillClusters.map((cluster) => (
            <li>
              <article class="bg-card border-border h-full rounded-xl border p-5 shadow-sm">
                <h3 class="text-foreground text-lg font-semibold">{cluster.title}</h3>
                <p class="text-muted-foreground mt-2 text-sm leading-relaxed">{cluster.description}</p>
                <ul class="mt-4 flex flex-wrap gap-2" role="list">
                  {cluster.tags.map((tag) => <li class="bg-secondary text-secondary-foreground rounded-full px-3 py-1 text-xs font-medium">{tag}</li>)}
                </ul>
              </article>
            </li>
          ))
        }
      </ul>
    </section>
  </section>
</Layout>
