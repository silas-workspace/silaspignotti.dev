---
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
import { SITE } from '@/consts'
import { getCollection } from 'astro:content'
import { badgeVariants } from '@/components/ui/badge'
import { Calendar, Award, GraduationCap, Briefcase, Brain, Sparkles, Server, Languages } from 'lucide-react'

const currentUrl = Astro.url
const page = (await getCollection('pages')).find((entry) => entry.data.slug === '/about')

if (!page) {
  throw new Error('Missing pages/about.md content entry')
}

// Access raw markdown body - try different properties
const rawBody = (page.body ?? (page as any).rendered?.body ?? '').replace(/\r\n/g, '\n')

// Helper to extract content between headings
const extractSection = (title: string) => {
  const escaped = title.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
  const regex = new RegExp(`(?:^|\\n)##\\s+${escaped}\\s*\\n+([\\s\\S]*?)(?=\\n##\\s+(?!#)|$)`)
  const match = rawBody.match(regex)
  return match ? match[1].trim() : ''
}

// Parse intro - everything before first ## 
const introMatch = rawBody.match(/^#\s+About\s*\n+([\s\S]*?)(?=\n##\s+)/)
const intro = introMatch ? introMatch[1].trim() : rawBody.split('##')[0].replace('# About', '').trim()

// Parse Experience
const experienceSection = extractSection('Experience')
const experienceItems: { role: string; company: string; date: string; description: string }[] = experienceSection
  ? experienceSection.split(/\n###\s+/)
      .filter((part: string) => Boolean(part))
      .map((part: string) => {
        // Remove any ### prefix from all lines
        const cleanPart = part.replace(/^###\s+/gm, '').trim()
        const lines = cleanPart.split('\n').map((l: string) => l.trim()).filter((l: string) => Boolean(l))
        if (lines.length === 0) return null
        
        const titleLine = lines[0] || ''
        const date = lines[1] || ''
        const description = lines.slice(2).join('\n').trim()
        
        const [role, company] = titleLine.includes('·') 
          ? titleLine.split('·').map((s: string) => s.trim())
          : [titleLine.trim(), '']
        
        if (!role) return null
        return { role, company, date, description }
      })
      .filter((item: any): item is { role: string; company: string; date: string; description: string } => Boolean(item))
  : []

// Parse Education  
const educationSection = extractSection('Education')
const educationItems = educationSection
  ? educationSection.split(/\n###\s+/)
      .filter(Boolean)
      .map(part => {
        const lines = part.split('\n').map(l => l.trim()).filter(Boolean)
        if (lines.length === 0) return null
        
        const titleLine = (lines[0] || '').replace(/^###\s*/, '').trim()
        const date = lines[1] || ''
        const gpaOrNote = lines[2] || ''
        const details = lines.slice(3).join('\n').trim()
        
        const [degree, institution] = titleLine.includes('·')
          ? titleLine.split('·').map(s => s.trim())
          : [titleLine.trim(), '']
        
        const gpaMatch = gpaOrNote.match(/GPA\s+([\d.]+)/)
        const gpa = gpaMatch ? gpaMatch[1] : null
        
        if (!degree) return null
        return { degree, institution, date, gpa, details }
      })
      .filter(Boolean)
  : []

// Parse Skills
const skillsSection = extractSection('Skills')
const skillsItems = skillsSection
  ? skillsSection.split(/\n###\s+/)
      .filter(Boolean)
      .map(part => {
        const lines = part.split('\n').map(l => l.trim()).filter(Boolean)
        if (lines.length === 0) return null
        
        const title = (lines[0] || '').replace(/^###\s*/, '').trim()
        const rest = lines.slice(1).join('\n').trim()
        
        // Extract description and tags
        const codeBlockMatch = rest.match(/(`[^`]+`\s*)+/)
        let description = rest
        let tags: string[] = []
        
        if (codeBlockMatch) {
          tags = rest.match(/`([^`]+)`/g)?.map(t => t.replace(/`/g, '')) ?? []
          // Remove the code block from description
          description = rest.replace(/(`[^`]+`\s*)+/, '').trim()
        }
        
        if (!title) return null
        return { title, description, tags }
      })
      .filter(Boolean)
  : []

// Icon mapping for skills
const getSkillIcon = (title: string) => {
  const t = title.toLowerCase()
  if (t.includes('geospatial') || t.includes('geo')) return Brain
  if (t.includes('ai') || t.includes('automation') || t.includes('assisted')) return Sparkles
  if (t.includes('infrastructure') || t.includes('tooling')) return Server
  if (t.includes('language')) return Languages
  return Sparkles
}
---

<Layout canonicalUrl={currentUrl}>
  <PageHead
    slot="head"
    title={page.data.title}
    description={page.data.description}
    imagePath={page.data.ogImage}
  />

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Silas Pignotti',
      jobTitle: 'Geo Data Scientist',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Berlin',
        addressCountry: 'DE',
      },
      url: SITE.href,
      email: SITE.email,
      sameAs: [
        'https://github.com/spignotti',
        'https://www.linkedin.com/in/silas-pignotti/',
      ],
    })}
  />

  <section class="mx-auto w-full max-w-7xl px-4 pb-8 sm:px-8 lg:px-12">
    <h1 class="font-custom mb-8 text-4xl font-bold text-foreground sm:text-5xl">About</h1>
    
    <!-- Intro -->
    {intro && (
      <div class="mb-12">
        <div class="prose prose-neutral dark:prose-invert max-w-none">
          {intro.split('\n\n').filter(Boolean).map(paragraph => (
            <p class="text-lg leading-relaxed text-foreground/90">{paragraph.replace(/\n/g, ' ')}</p>
          ))}
        </div>
      </div>
    )}

    <!-- Experience -->
    {experienceItems.length > 0 && (
      <section aria-labelledby="experience-heading" class="mb-12">
        <div class="mb-6 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-full border border-border bg-card shadow-sm">
            <Briefcase className="h-5 w-5 text-primary" />
          </div>
          <h2 id="experience-heading" class="font-custom text-2xl font-bold text-foreground sm:text-3xl">Experience</h2>
        </div>
        
        <div class="space-y-4">
          {experienceItems.map((item) => (
            <article class="rounded-2xl border border-border/60 bg-card p-5 shadow-sm transition-all duration-300 hover:shadow-md">
              <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex-1">
                  <h3 class="text-lg font-semibold text-foreground">{item.role}</h3>
                  {item.company && <p class="text-base text-muted-foreground">{item.company}</p>}
                </div>
                <div class="flex flex-wrap items-center gap-2">
                  {item.date && (
                    <div class="flex items-center gap-1.5 rounded-full border border-primary/20 bg-primary/10 px-3 py-1 text-sm font-semibold text-primary">
                      <Calendar className="h-3.5 w-3.5" />
                      <span>{item.date}</span>
                    </div>
                  )}
                </div>
              </div>
              {item.description && (
                <p class="mt-3 text-base leading-relaxed text-foreground/80">{item.description}</p>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Education -->
    {educationItems.length > 0 && (
      <section aria-labelledby="education-heading" class="mb-12">
        <div class="mb-6 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-full border border-border bg-card shadow-sm">
            <GraduationCap className="h-5 w-5 text-primary" />
          </div>
          <h2 id="education-heading" class="font-custom text-2xl font-bold text-foreground sm:text-3xl">Education</h2>
        </div>
        
        <div class="space-y-4">
          {educationItems.map((item) => (
            <article class="rounded-2xl border border-border/60 bg-card p-5 shadow-sm transition-all duration-300 hover:shadow-md">
              <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex-1">
                  <h3 class="text-lg font-semibold text-foreground">{item.degree}</h3>
                  {item.institution && <p class="text-base text-muted-foreground">{item.institution}</p>}
                </div>
                <div class="flex flex-col items-end gap-2">
                  {item.date && (
                    <div class="flex items-center gap-1.5 rounded-full border border-primary/20 bg-primary/10 px-3 py-1 text-sm font-semibold text-primary">
                      <Calendar className="h-3.5 w-3.5" />
                      <span>{item.date}</span>
                    </div>
                  )}
                  {item.gpa && (
                    <div class="flex items-center gap-1.5 rounded-full border border-green-500/20 bg-green-500/10 px-3 py-1 text-sm font-semibold text-green-600 dark:text-green-400">
                      <Award className="h-3.5 w-3.5" />
                      <span>GPA {item.gpa}</span>
                    </div>
                  )}
                </div>
              </div>
              {item.details && (
                <div class="mt-3 space-y-1 text-sm text-foreground/70">
                  {item.details.split('\n').filter(l => l.trim()).map(line => (
                    <p>{line.replace(/^[-•]\s*/, '')}</p>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Skills -->
    {skillsItems.length > 0 && (
      <section aria-labelledby="skills-heading">
        <div class="mb-6 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-full border border-border bg-card shadow-sm">
            <Brain className="h-5 w-5 text-primary" />
          </div>
          <h2 id="skills-heading" class="font-custom text-2xl font-bold text-foreground sm:text-3xl">Skills</h2>
        </div>
        
        <div class="grid gap-5 md:grid-cols-2">
          {skillsItems.map((skill) => {
            return (
              <article class="rounded-2xl border border-border/60 bg-card p-5 shadow-sm transition-all duration-300 hover:shadow-md">
                <div class="flex flex-col gap-3">
                  <div class="flex-1">
                    <h3 class="text-base font-semibold text-foreground">{skill.title}</h3>
                    {skill.description && (
                      <p class="mt-1 text-sm leading-relaxed text-foreground/70">{skill.description}</p>
                    )}
                    
                    {skill.tags.length > 0 && (
                      <ul class="mt-3 flex flex-wrap gap-2" role="list">
                        {skill.tags.map((tag) => (
                          <li class={badgeVariants({ variant: 'secondary' })}>{tag}</li>
                        ))}
                      </ul>
                    )}
                  </div>
                </div>
              </article>
            )
          })}
        </div>
      </section>
    )}
  </section>
</Layout>
