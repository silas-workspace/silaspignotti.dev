---
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
import { SITE } from '@/consts'
import { getCollection } from 'astro:content'
import { badgeVariants } from '@/components/ui/badge'
import { Calendar, Award, GraduationCap, Briefcase, Brain, Sparkles, Server, Languages } from 'lucide-react'

const currentUrl = Astro.url
const page = (await getCollection('pages')).find((entry) => entry.data.slug === '/about')

if (!page) {
  throw new Error('Missing pages/about.md content entry')
}

const rawBody = (page.body ?? '').replace(/\r\n/g, '\n')

// Extract intro paragraphs (content before first ##)
const introMatch = rawBody.match(/(?:^#\s+.*\n+)?([\s\S]*?)(?=\n##\s+|$)/)
const intro = introMatch?.[1]?.replace(/^#\s+.*\n+/, '').trim() ?? ''

// Parse Experience section
const extractSection = (title: string) => {
  const escaped = title.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
  const regex = new RegExp(`##\\s+${escaped}\\s*([\\s\\S]*?)(?=\n##\\s+|$)`, 'm')
  return rawBody.match(regex)?.[1]?.trim() ?? ''
}

const experienceSection = extractSection('Experience')
const experienceItems = experienceSection
  .split(/\n###\s+/)
  .map((part, index) => {
    const normalizedPart = (index === 0 ? part.replace(/^###\s+/, '') : part).trim()
    if (!normalizedPart) return null
    
    // Split by newline to get title line, date, and description
    const lines = normalizedPart.split('\n').filter(l => l.trim())
    const titleLine = lines[0] ?? ''
    const date = lines[1] ?? ''
    const description = lines.slice(2).join('\n').trim()
    
    // Extract company and role from title line (format: "Role · Company")
    const [role, company] = titleLine.includes('·') 
      ? titleLine.split('·').map(s => s.trim())
      : [titleLine.trim(), '']
    
    return { role, company, date, description }
  })
  .filter((item): item is { role: string; company: string; date: string; description: string } => Boolean(item))

// Parse Education section
const educationSection = extractSection('Education')
const educationItems = educationSection
  .split(/\n###\s+/)
  .map((part, index) => {
    const normalizedPart = (index === 0 ? part.replace(/^###\s+/, '') : part).trim()
    if (!normalizedPart) return null
    
    const lines = normalizedPart.split('\n').filter(l => l.trim())
    const titleLine = lines[0] ?? ''
    const date = lines[1] ?? ''
    const gpaOrNote = lines[2] ?? ''
    const details = lines.slice(3).join('\n').trim()
    
    // Extract degree and institution
    const [degree, institution] = titleLine.includes('·')
      ? titleLine.split('·').map(s => s.trim())
      : [titleLine.trim(), '']
    
    // Extract GPA if present
    const gpaMatch = gpaOrNote.match(/GPA\s+([\d.]+)/)
    const gpa = gpaMatch ? gpaMatch[1] : null
    
    return { degree, institution, date, gpa, details }
  })
  .filter((item): item is { degree: string; institution: string; date: string; gpa: string | null; details: string } => Boolean(item))

// Parse Skills section
const skillsSection = extractSection('Skills')
const skillsItems = skillsSection
  .split(/\n###\s+/)
  .map((part, index) => {
    const normalizedPart = (index === 0 ? part.replace(/^###\s+/, '') : part).trim()
    if (!normalizedPart) return null
    
    const lines = normalizedPart.split('\n').filter(l => l.trim())
    const title = lines[0] ?? ''
    const description = lines.slice(1).join('\n').trim()
    
    // Extract inline code tags as skill chips
    const tags = normalizedPart.match(/`([^`]+)`/g)?.map(t => t.replace(/`/g, '')) ?? []
    
    return { title, description, tags }
  })
  .filter((item): item is { title: string; description: string; tags: string[] } => Boolean(item))

// Icon mapping for skills
const getSkillIcon = (title: string) => {
  const t = title.toLowerCase()
  if (t.includes('geospatial') || t.includes('geo')) return Brain
  if (t.includes('ai') || t.includes('automation')) return Sparkles
  if (t.includes('infrastructure') || t.includes('tooling')) return Server
  if (t.includes('language')) return Languages
  return Sparkles
}
---

<Layout canonicalUrl={currentUrl}>
  <PageHead
    slot="head"
    title={page.data.title}
    description={page.data.description}
    imagePath={page.data.ogImage}
  />

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Silas Pignotti',
      jobTitle: 'Geo Data Scientist',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Berlin',
        addressCountry: 'DE',
      },
      url: SITE.href,
      email: SITE.email,
      sameAs: [
        'https://github.com/spignotti',
        'https://www.linkedin.com/in/silas-pignotti/',
      ],
    })}
  />

  <section class="mx-auto w-full max-w-7xl px-4 pb-8 sm:px-8 lg:px-12">
    <h1 class="sr-only">{page.data.title}</h1>
    
    <!-- Intro -->
    <div class="mb-12 rounded-3xl border border-border/60 bg-linear-to-b from-muted/50 to-background p-5 sm:p-10 lg:p-12">
      <div class="prose prose-neutral dark:prose-invert max-w-none">
        {intro.split('\n\n').map(paragraph => (
          <p class="text-lg leading-relaxed text-foreground/90">{paragraph}</p>
        ))}
      </div>
    </div>

    <!-- Experience -->
    {experienceItems.length > 0 && (
      <section aria-labelledby="experience-heading" class="mb-12">
        <div class="mb-6 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-full border border-border bg-card shadow-sm">
            <Briefcase className="h-5 w-5 text-primary" />
          </div>
          <h2 id="experience-heading" class="font-custom text-2xl font-bold text-foreground sm:text-3xl">Experience</h2>
        </div>
        
        <div class="space-y-4">
          {experienceItems.map((item) => (
            <article class="rounded-2xl border border-border/60 bg-card p-5 shadow-sm transition-all duration-300 hover:shadow-md">
              <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex-1">
                  <h3 class="text-lg font-semibold text-foreground">{item.role}</h3>
                  {item.company && <p class="text-base text-muted-foreground">{item.company}</p>}
                </div>
                <div class="flex items-center gap-2 text-sm text-muted-foreground">
                  <Calendar className="h-4 w-4" />
                  <span>{item.date}</span>
                </div>
              </div>
              <p class="mt-3 text-base leading-relaxed text-foreground/80">{item.description}</p>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Education -->
    {educationItems.length > 0 && (
      <section aria-labelledby="education-heading" class="mb-12">
        <div class="mb-6 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-full border border-border bg-card shadow-sm">
            <GraduationCap className="h-5 w-5 text-primary" />
          </div>
          <h2 id="education-heading" class="font-custom text-2xl font-bold text-foreground sm:text-3xl">Education</h2>
        </div>
        
        <div class="space-y-4">
          {educationItems.map((item) => (
            <article class="rounded-2xl border border-border/60 bg-card p-5 shadow-sm transition-all duration-300 hover:shadow-md">
              <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex-1">
                  <h3 class="text-lg font-semibold text-foreground">{item.degree}</h3>
                  {item.institution && <p class="text-base text-muted-foreground">{item.institution}</p>}
                </div>
                <div class="flex flex-wrap items-center gap-2">
                  <div class="flex items-center gap-1.5 rounded-full border border-primary/20 bg-primary/10 px-2.5 py-1 text-xs font-semibold text-primary">
                    <Calendar className="h-3 w-3" />
                    <span>{item.date}</span>
                  </div>
                  {item.gpa && (
                    <div class="flex items-center gap-1.5 rounded-full border border-green-500/20 bg-green-500/10 px-2.5 py-1 text-xs font-semibold text-green-600 dark:text-green-400">
                      <Award className="h-3 w-3" />
                      <span>GPA {item.gpa}</span>
                    </div>
                  )}
                </div>
              </div>
              {item.details && (
                <div class="mt-3 space-y-1 text-sm text-foreground/70">
                  {item.details.split('\n').filter(l => l.trim()).map(line => (
                    <p>{line.replace(/^[-•]\s*/, '')}</p>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Skills -->
    {skillsItems.length > 0 && (
      <section aria-labelledby="skills-heading">
        <div class="mb-6 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-full border border-border bg-card shadow-sm">
            <Brain className="h-5 w-5 text-primary" />
          </div>
          <h2 id="skills-heading" class="font-custom text-2xl font-bold text-foreground sm:text-3xl">Skills</h2>
        </div>
        
        <div class="grid gap-5 md:grid-cols-2">
          {skillsItems.map((skill) => {
            const IconComponent = getSkillIcon(skill.title)
            return (
              <article class="rounded-2xl border border-border/60 bg-card p-5 shadow-sm transition-all duration-300 hover:shadow-md">
                <div class="flex items-start gap-3">
                  <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary/10">
                    <IconComponent className="h-4 w-4 text-primary" />
                  </div>
                  <div class="flex-1">
                    <h3 class="text-base font-semibold text-foreground">{skill.title}</h3>
                    <p class="mt-1 text-sm leading-relaxed text-foreground/70">{skill.description}</p>
                    
                    {skill.tags.length > 0 && (
                      <ul class="mt-3 flex flex-wrap gap-2" role="list">
                        {skill.tags.map((tag) => (
                          <li class={badgeVariants({ variant: 'secondary' })}>{tag}</li>
                        ))}
                      </ul>
                    )}
                  </div>
                </div>
              </article>
            )
          })}
        </div>
      </section>
    )}
  </section>
</Layout>
