---
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
import { SITE } from '@/consts'
import { getCollection, render } from 'astro:content'

const currentUrl = Astro.url
const page = (await getCollection('pages')).find((entry) => entry.data.slug === '/about')

if (!page) {
  throw new Error('Missing pages/about.md content entry')
}

const { Content } = await render(page)
---

<Layout canonicalUrl={currentUrl}>
  <PageHead
    slot="head"
    title={page.data.title}
    description={page.data.description}
    imagePath={page.data.ogImage}
  />

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Silas Pignotti',
      jobTitle: 'Geo Data Scientist',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Berlin',
        addressCountry: 'DE',
      },
      url: SITE.href,
      email: SITE.email,
      sameAs: [
        'https://github.com/spignotti',
        'https://www.linkedin.com/in/silas-pignotti/',
      ],
    })}
  />

  <article class="prose prose-neutral dark:prose-invert max-w-none px-4 py-8 sm:px-8 lg:px-16">
    <Content />
  </article>
</Layout>
