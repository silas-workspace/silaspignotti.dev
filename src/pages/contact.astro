---
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
import { getCollection, render } from 'astro:content'

const currentUrl = Astro.url
const page = (await getCollection('pages')).find((entry) => entry.data.slug === '/contact')

if (!page) {
  throw new Error('Missing pages/contact.md content entry')
}

const { Content } = await render(page)
---

<Layout canonicalUrl={currentUrl} isWide>
  <PageHead
    slot="head"
    title={page.data.title}
    description={page.data.description}
    imagePath={page.data.ogImage}
  />

  <section class="mx-auto w-full max-w-7xl px-4 py-8 sm:px-8 lg:px-12">
    <article class="prose prose-neutral dark:prose-invert max-w-none">
      <h1 class="sr-only">{page.data.title}</h1>
      <Content />
    </article>
  </section>
</Layout>
