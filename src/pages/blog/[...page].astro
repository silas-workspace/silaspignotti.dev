---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import BlogCard from '@/components/react/blog-card'
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
import { getAllPosts } from '@/lib/data-utils'
import type { PaginateFunction } from 'astro'

export async function getStaticPaths({
  paginate,
}: {
  paginate: PaginateFunction
}) {
  const allPosts = await getAllPosts()
  return paginate(allPosts, { pageSize: 5 })
}

const { page } = Astro.props

const categories = [
  {
    title: 'Project Writeups',
    description:
      "End-to-end breakdowns of portfolio projects. What the problem was, how I solved it, what I'd do differently.",
  },
  {
    title: 'System Design & Meta',
    description:
      'How I structure my work: AI coding workflows, knowledge management, prompt engineering, Python tooling.',
  },
  {
    title: 'Tools & Reviews',
    description:
      "Honest reviews of tools I use daily. What works, what doesn't, and why.",
  },
]

const currentUrl = Astro.url
---

<Layout canonicalUrl={currentUrl}>
  <PageHead
    slot="head"
    title="Blog"
    description="Technical writing on geospatial data science, AI-powered automation, and the tools I build along the way."
  />

  <Breadcrumbs
    items={[
      { label: 'Blog', href: '/blog', icon: 'lucide:archive' },
    ]}
  />

  <section class="max-screen mt-12 px-4 md:px-6">
    <header class="mb-10">
      <h1 class="font-custom text-foreground text-4xl font-bold">Blog</h1>
      <p class="text-muted-foreground text-md mt-3 max-w-4xl">
        Technical writing on geospatial data science, AI-powered automation, and the tools I build along the way. I write about things I actually work on: project deep dives, architecture decisions, tooling setups, and lessons learned. No thought leadership, no hot takes for the sake of engagement.
      </p>
    </header>

    <section class="mb-12" aria-labelledby="blog-categories-heading">
      <h2 id="blog-categories-heading" class="font-custom text-foreground mb-4 text-2xl font-bold">
        Categories
      </h2>
      <ul class="flex flex-wrap gap-3" role="list">
        {
          categories.map((category) => (
            <li class="bg-card border-border max-w-full rounded-full border px-4 py-2 text-sm">
              <p class="text-foreground font-medium">{category.title}</p>
              <p class="text-muted-foreground mt-1 text-xs leading-relaxed">{category.description}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <section aria-labelledby="blog-posts-heading" class="mb-8">
      <h2 id="blog-posts-heading" class="font-custom text-foreground mb-4 text-2xl font-bold">
        Posts
      </h2>

      {
        page.data.length > 0 ? (
          <ul class="flex flex-col gap-4" role="list">
            {page.data.map((post) => (
              <li>
                <BlogCard entry={post} />
              </li>
            ))}
          </ul>
        ) : (
          <div class="bg-muted/40 border-border rounded-xl border border-dashed p-6">
            <p class="text-muted-foreground text-sm">First articles are in the pipeline.</p>
          </div>
        )
      }

      <p class="text-muted-foreground mt-4 text-sm">
        Blog posts will be added as Markdown/MDX files in the content collection with title, date, category, tags, description, and slug.
      </p>
    </section>
  </section>
</Layout>
