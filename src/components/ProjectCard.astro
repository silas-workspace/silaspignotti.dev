---
import { withBasePath } from '@/lib/paths'
import { cn } from '@/lib/utils'
import type { CollectionEntry } from 'astro:content'
import { Calendar, MapPin } from 'lucide-react'

interface Props {
  project: CollectionEntry<'projects'>
  tagLimit?: number
}

const {
  project,
  tagLimit = 3,
} = Astro.props as Props

const projectPath = `/projects/${project.data.slug}`
const tags = project.data.tags.slice(0, tagLimit)
const remainingTags = project.data.tags.length - tagLimit
const displayYear = project.data.completed ? project.data.year : 'Ongoing'
---

<a
  href={projectPath}
  class={cn(
    'group flex flex-col overflow-hidden rounded-2xl border border-border/60 bg-card shadow-sm',
    'transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5',
    'aspect-[4/3]'
  )}
>
  <!-- Cover Image -->
  <div class="aspect-[16/10] w-full overflow-hidden bg-muted/30">
    <img
      src={withBasePath(project.data.cover)}
      alt={`${project.data.title} project cover`}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
      loading="lazy"
    />
  </div>

  <!-- Content -->
  <div class="flex flex-1 flex-col justify-between p-4">
    <div>
      <!-- Title -->
      <h3 class="mb-1 text-lg font-semibold text-foreground line-clamp-1 group-hover:text-primary">
        {project.data.title}
      </h3>
      
      <!-- Tagline -->
      {project.data.tagline && (
        <p class="text-sm text-muted-foreground line-clamp-2">
          {project.data.tagline}
        </p>
      )}
    </div>

    <!-- Bottom row: Tags + Year -->
    <div class="mt-3 flex items-end justify-between gap-2">
      <!-- Tags -->
      <div class="flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span class="inline-flex rounded-full bg-secondary px-2 py-0.5 text-xs font-medium text-foreground/80">
            {tag}
          </span>
        ))}
        {remainingTags > 0 && (
          <span class="inline-flex rounded-full bg-secondary px-2 py-0.5 text-xs font-medium text-muted-foreground">
            +{remainingTags}
          </span>
        )}
      </div>

      <!-- Year/Ongoing -->
      <div class="flex items-center gap-1 text-xs text-muted-foreground">
        <Calendar className="h-3 w-3" />
        <span>{displayYear}</span>
      </div>
    </div>
  </div>
</a>
