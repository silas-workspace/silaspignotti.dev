---
import { withBasePath } from '@/lib/paths'
import { cn } from '@/lib/utils'
import type { CollectionEntry } from 'astro:content'
import { Calendar, Layers, Terminal, Satellite, MapPin, FileSearch, LayoutDashboard, Wand2, Trees, Building2 } from 'lucide-react'

interface Props {
  project: CollectionEntry<'projects'>
  tagLimit?: number
}

const {
  project,
  tagLimit = 3,
} = Astro.props as Props

const projectPath = `/projects/${project.data.slug}`
const tags = project.data.tags.slice(0, tagLimit)
const remainingTags = project.data.tags.length - tagLimit
const displayYear = project.data.completed ? project.data.year : 'Ongoing'

// Icon mapping for coverIcon
const iconMap: Record<string, typeof Building2> = {
  'layers': Layers,
  'terminal': Terminal,
  'satellite': Satellite,
  'map-pin': MapPin,
  'file-search': FileSearch,
  'layout-dashboard': LayoutDashboard,
  'wand-2': Wand2,
  'trees': Trees,
  'building-2': Building2,
}

const IconComponent = iconMap[project.data.coverIcon] || Layers
---

<a
  href={projectPath}
  class={cn(
    'group flex h-full flex-col overflow-hidden rounded-2xl border border-border/60 bg-card p-5 shadow-sm',
    'transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5',
  )}
>
  <!-- Icon + Title + Tagline -->
  <div class="flex items-start gap-3 mb-3">
    <!-- Icon Circle -->
    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-primary/50">
      <IconComponent className="h-5 w-5 text-primary" />
    </div>
    
    <div class="flex-1 min-w-0">
      <!-- Title -->
      <h3 class="text-lg font-semibold text-foreground line-clamp-1 group-hover:text-primary">
        {project.data.title}
      </h3>
      
      <!-- Tagline -->
      {project.data.tagline && (
        <p class="text-sm text-muted-foreground line-clamp-2 mt-0.5">
          {project.data.tagline}
        </p>
      )}
    </div>
  </div>

  <!-- Separator line -->
  <div class="border-t border-border/40 my-3"></div>

  <!-- Bottom row: Tags + Year -->
  <div class="flex items-end justify-between gap-2 mt-auto">
    <!-- Tags -->
    <div class="flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="inline-flex rounded-full bg-secondary px-2 py-0.5 text-xs font-medium text-foreground/80">
          {tag}
        </span>
      ))}
      {remainingTags > 0 && (
        <span class="inline-flex rounded-full bg-secondary px-2 py-0.5 text-xs font-medium text-muted-foreground">
          +{remainingTags}
        </span>
      )}
    </div>

    <!-- Year/Ongoing -->
    <div class="flex items-center gap-1 text-xs text-muted-foreground">
      <Calendar className="h-3 w-3" />
      <span>{displayYear}</span>
    </div>
  </div>
</a>
